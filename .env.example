# Runtime environment: "development" | "production"
ENV=development

# HTTP server port
PORT=8080

# Database driver: "sqlite" | "postgres"
DB_DRIVER=sqlite

# SQLite file path (used when DB_DRIVER=sqlite)
DB_PATH=foodscheduler.db

# PostgreSQL DSN (used when DB_DRIVER=postgres)
# DB_URL=postgres://user:password@localhost:5432/foodscheduler?sslmode=disable

# JWT signing secret — must be set in production
JWT_SECRET=change-me-in-production

# USDA FoodData Central API key
# Get a free key at https://fdc.nal.usda.gov/api-guide.html
USDA_API_KEY=

# CORS allowed origins (comma-separated). Defaults to * (all origins).
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=
